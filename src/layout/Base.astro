---
import "../styles/globals.css";
import { getServerAdmin } from "../lib/supabase";
import { ModeToggle } from "../components/ModeToggle";
import {
  ChevronLeft,
  ChevronRight,
  Home,
  ShoppingBag,
  Users,
  Package,
  ClipboardList,
  Tag,
  CreditCard,
  LogOut,
  Grid3X3,
  Truck,
  BarChart3,
  PanelLeftClose,
  PanelLeftOpen,
  X
} from "lucide-react";

interface Props {
  title: string;
}

const description = "Panel de Administración - Rental Mario Hans";
const { title } = Astro.props;
const ogImageURL = new URL("hero.png", import.meta.env.SITE).href;
const canonicalURL = new URL(Astro.url).href;

const adminSession = await getServerAdmin(Astro);
const isAuthenticated = !!adminSession;
const currentPath = Astro.url.pathname;
---

<html lang="es" class="h-full w-full">
  <head>
    <title>{title}</title>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content="Astro" />
    <meta name="description" content={description} />
    <meta property="twitter:image" content={ogImageURL} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />

    <style is:inline>
      /* ── Theme base ── */
      .dark { background-color: hsl(0 0% 3.9%); color: hsl(0 0% 98%); }
      body { background-color: hsl(0 0% 100%); color: hsl(0 0% 3.9%); }
      html.dark body { background-color: hsl(0 0% 3.9%); color: hsl(0 0% 98%); }

      /* ── Sidebar ── */
      #sidebar {
        width: var(--sidebar-width, 256px);
        transition: width 280ms cubic-bezier(0.4, 0, 0.2, 1);
        will-change: width;
      }

      #sidebar .sidebar-inner {
        background-color: hsl(0 0% 100%);
        border-right: 1px solid hsl(0 0% 89.8%);
      }
      html.dark #sidebar .sidebar-inner {
        background-color: hsl(0 0% 3.9%);
        border-right-color: hsl(0 0% 14.9%);
      }

      /* ── Sidebar text fade ── */
      .sidebar-label {
        opacity: 1;
        width: auto;
        overflow: hidden;
        white-space: nowrap;
        transition: opacity 200ms cubic-bezier(0.4, 0, 0.2, 1), width 280ms cubic-bezier(0.4, 0, 0.2, 1);
      }
      .sidebar-collapsed .sidebar-label {
        opacity: 0;
        width: 0;
        pointer-events: none;
      }

      /* ── Submenu collapse ── */
      .sidebar-submenu {
        max-height: 0;
        overflow: hidden;
        transition: max-height 250ms cubic-bezier(0.4, 0, 0.2, 1), opacity 200ms ease;
        opacity: 0;
      }
      .sidebar-submenu.open {
        max-height: 200px;
        opacity: 1;
      }
      .sidebar-collapsed .sidebar-submenu {
        max-height: 0 !important;
        opacity: 0 !important;
      }

      /* ── Submenu arrow ── */
      .submenu-arrow {
        transition: transform 250ms cubic-bezier(0.4, 0, 0.2, 1);
      }
      .submenu-arrow.rotated {
        transform: rotate(90deg);
      }

      /* ── Sidebar nav items ── */
      .sidebar-nav-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.5rem 0.75rem;
        border-radius: 0.5rem;
        font-size: 0.875rem;
        font-weight: 500;
        color: hsl(0 0% 45.1%);
        transition: color 150ms ease, background-color 150ms ease;
        position: relative;
        white-space: nowrap;
      }
      html.dark .sidebar-nav-item { color: hsl(0 0% 63.9%); }
      .sidebar-nav-item:hover {
        color: hsl(0 0% 9%);
        background-color: hsl(0 0% 95.1%);
      }
      html.dark .sidebar-nav-item:hover {
        color: hsl(0 0% 98%);
        background-color: hsl(0 0% 14.9%);
      }
      .sidebar-nav-item.active {
        color: hsl(0 0% 9%);
        background-color: hsl(0 0% 95.1%);
      }
      html.dark .sidebar-nav-item.active {
        color: hsl(0 0% 98%);
        background-color: hsl(0 0% 14.9%);
      }
      .sidebar-nav-item .nav-icon {
        flex-shrink: 0;
        width: 1.25rem;
        height: 1.25rem;
      }

      /* ── Collapsed center icons ── */
      .sidebar-collapsed .sidebar-nav-item {
        justify-content: center;
        padding: 0.625rem;
      }
      .sidebar-collapsed .sidebar-nav-item .nav-icon {
        width: 1.375rem;
        height: 1.375rem;
      }

      /* ── Tooltip on hover (collapsed) ── */
      .sidebar-nav-item .nav-tooltip {
        position: absolute;
        left: calc(100% + 0.75rem);
        top: 50%;
        transform: translateY(-50%);
        padding: 0.375rem 0.75rem;
        border-radius: 0.375rem;
        font-size: 0.75rem;
        font-weight: 500;
        white-space: nowrap;
        pointer-events: none;
        opacity: 0;
        transition: opacity 150ms ease;
        background-color: hsl(0 0% 9%);
        color: hsl(0 0% 98%);
        z-index: 50;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,.1), 0 2px 4px -2px rgba(0,0,0,.1);
      }
      html.dark .sidebar-nav-item .nav-tooltip {
        background-color: hsl(0 0% 98%);
        color: hsl(0 0% 9%);
      }
      .sidebar-collapsed .sidebar-nav-item:hover .nav-tooltip {
        opacity: 1;
      }
      :not(.sidebar-collapsed) .sidebar-nav-item .nav-tooltip {
        display: none;
      }

      /* ── Toggle button ── */
      .sidebar-toggle {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 1.75rem;
        height: 1.75rem;
        border-radius: 0.375rem;
        color: hsl(0 0% 45.1%);
        transition: color 150ms ease, background-color 150ms ease;
      }
      .sidebar-toggle:hover {
        color: hsl(0 0% 9%);
        background-color: hsl(0 0% 95.1%);
      }
      html.dark .sidebar-toggle { color: hsl(0 0% 63.9%); }
      html.dark .sidebar-toggle:hover {
        color: hsl(0 0% 98%);
        background-color: hsl(0 0% 14.9%);
      }

      /* ── Admin badge (collapsed) ── */
      .admin-info {
        overflow: hidden;
        transition: max-height 280ms cubic-bezier(0.4, 0, 0.2, 1), opacity 200ms ease, padding 280ms ease;
        max-height: 120px;
        opacity: 1;
      }
      .sidebar-collapsed .admin-info {
        max-height: 0;
        opacity: 0;
        padding-top: 0;
        padding-bottom: 0;
      }

      /* ── Logout ── */
      .sidebar-logout {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.5rem 0.75rem;
        border-radius: 0.5rem;
        font-size: 0.875rem;
        font-weight: 500;
        width: 100%;
        color: hsl(0 62.8% 30.6%);
        transition: color 150ms ease, background-color 150ms ease;
      }
      html.dark .sidebar-logout { color: hsl(0 62.8% 60.6%); }
      .sidebar-logout:hover {
        background-color: hsl(0 100% 97.1%);
        color: hsl(0 72.2% 50.6%);
      }
      html.dark .sidebar-logout:hover {
        background-color: hsl(0 62.8% 10%);
        color: hsl(0 62.8% 70%);
      }
      .sidebar-collapsed .sidebar-logout { justify-content: center; padding: 0.625rem; }

      /* ── Content shift ── */
      #main-content, #footer {
        margin-left: var(--sidebar-width, 0px);
        transition: margin-left 280ms cubic-bezier(0.4, 0, 0.2, 1);
      }

      /* ── Footer ── */
      #footer {
        background-color: hsl(0 0% 100%);
        color: hsl(0 0% 45.1%);
        border-top: 1px solid hsl(0 0% 89.8%);
      }
      html.dark #footer {
        background-color: hsl(0 0% 3.9%);
        color: hsl(0 0% 63.9%);
        border-top-color: hsl(0 0% 14.9%);
      }
      #footer a { color: inherit; }
      #footer a:hover { text-decoration: underline; }

      /* ── Mobile overlay ── */
      #sidebar-overlay {
        position: fixed;
        inset: 0;
        background-color: rgba(0,0,0,0.5);
        z-index: 15;
        opacity: 0;
        pointer-events: none;
        transition: opacity 280ms ease;
      }
      #sidebar-overlay.visible {
        opacity: 1;
        pointer-events: auto;
      }

      /* ── Mobile: sidebar off-screen by default ── */
      @media (max-width: 767px) {
        #sidebar {
          transform: translateX(-100%);
          transition: transform 280ms cubic-bezier(0.4, 0, 0.2, 1), width 280ms cubic-bezier(0.4, 0, 0.2, 1);
          z-index: 20;
        }
        #sidebar.mobile-open {
          transform: translateX(0);
        }
        #main-content, #footer {
          margin-left: 0 !important;
        }
      }

      /* ── Mobile logo button ── */
      .mobile-logo-btn {
        padding: 0;
        background: transparent;
        border: none;
        cursor: pointer;
        transition: opacity 150ms ease, transform 150ms ease;
      }
      .mobile-logo-btn:hover { opacity: 0.8; }
      .mobile-logo-btn:active { transform: scale(0.92); }

      /* ── Logo section (cross-fade) ── */
      .sidebar-logo-wrap {
        position: relative;
        min-width: 2rem;
        min-height: 2.5rem;
        display: flex;
        align-items: center;
      }
      .sidebar-logo-full,
      .sidebar-logo-icon {
        transition: opacity 250ms cubic-bezier(0.4, 0, 0.2, 1);
      }
      .sidebar-logo-full {
        opacity: 1;
      }
      .sidebar-collapsed .sidebar-logo-full {
        opacity: 0;
        pointer-events: none;
        position: absolute;
      }
      .sidebar-logo-icon {
        opacity: 0;
        pointer-events: none;
        position: absolute;
      }
      .sidebar-collapsed .sidebar-logo-icon {
        opacity: 1;
        pointer-events: auto;
        position: static;
      }

      /* ── Section divider text ── */
      .sidebar-section-label {
        font-size: 0.6875rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: hsl(0 0% 63.9%);
        padding: 0.5rem 0.75rem 0.25rem;
        overflow: hidden;
        white-space: nowrap;
        transition: opacity 200ms ease;
      }
      html.dark .sidebar-section-label { color: hsl(0 0% 45.1%); }
      .sidebar-collapsed .sidebar-section-label { opacity: 0; height: 0; padding: 0; }
    </style>
  </head>
  <body class="flex flex-col min-h-screen w-full">

    <!-- Mobile menu trigger (MH logo) -->
    {isAuthenticated && (
      <button
        id="mobile-menu-btn"
        class="fixed top-4 left-4 z-30 md:hidden mobile-logo-btn"
        aria-label="Abrir menú"
      >
        <img
          src="/toggle-button-black.png"
          alt="Menú"
          class="h-9 w-9 logo-image"
          data-dark-src="/toggle-button-black.png"
          data-light-src="/toggle-button-white.png"
        />
      </button>
    )}

    <!-- Theme Toggle Button -->
    <div class="fixed top-4 right-4 z-30">
      <ModeToggle client:load />
    </div>

    <!-- Mobile overlay -->
    <div id="sidebar-overlay"></div>

    {isAuthenticated && (
      <aside id="sidebar" class="fixed left-0 top-0 h-screen z-20" data-current-path={currentPath}>
        <div class="sidebar-inner h-full flex flex-col overflow-hidden">
          <!-- Header: logo + toggle -->
          <div class="flex items-center justify-between px-4 py-4 border-b border-inherit">
            <div class="sidebar-logo-wrap">
              <div class="sidebar-logo-full">
                <a href="/dashboard">
                  <img
                    src="/logo-black.png"
                    alt="Mario Hans Rental"
                    class="h-10 w-auto logo-image"
                    data-dark-src="/logo-black.png"
                    data-light-src="/logo-white.png"
                    onerror="this.src='/placeholder-logo.svg'; this.onerror=null;"
                  />
                </a>
              </div>
              <div class="sidebar-logo-icon">
                <a href="/dashboard">
                  <img
                    src="/toggle-button-black.png"
                    alt="MH"
                    class="h-8 w-8 logo-image"
                    data-dark-src="/toggle-button-black.png"
                    data-light-src="/toggle-button-white.png"
                    onerror="this.src='/placeholder-icon.svg'; this.onerror=null;"
                  />
                </a>
              </div>
            </div>
            <!-- Desktop toggle -->
            <button class="sidebar-toggle hidden md:flex" onclick="toggleSidebar()" aria-label="Colapsar menú">
              <PanelLeftClose className="h-4 w-4 toggle-collapse-icon" />
              <PanelLeftOpen className="h-4 w-4 toggle-expand-icon hidden" />
            </button>
            <!-- Mobile close -->
            <button class="sidebar-toggle flex md:hidden" onclick="closeMobileSidebar()" aria-label="Cerrar menú">
              <X className="h-4 w-4" />
            </button>
          </div>

          <!-- Admin status indicator -->
          {adminSession && (
            <div class="admin-info px-4 pt-3 pb-1">
              <div class="flex items-center gap-2 px-1">
                <span class="inline-block h-2 w-2 rounded-full bg-emerald-500 flex-shrink-0"></span>
                <span class="text-xs font-medium text-muted-foreground sidebar-label">Administrador</span>
              </div>
            </div>
          )}

          <!-- Navigation -->
          <nav class="flex-1 overflow-y-auto overflow-x-hidden px-3 py-3 space-y-1">
            <a href="/dashboard" class={`sidebar-nav-item ${currentPath === '/dashboard' || currentPath === '/dashboard/' ? 'active' : ''}`}>
              <Home className="nav-icon" />
              <span class="sidebar-label">Dashboard</span>
              <span class="nav-tooltip">Dashboard</span>
            </a>

            <div class="sidebar-section-label">Gestión</div>

            <!-- Pedidos group -->
            <button onclick="toggleSubmenu('orders')" class="sidebar-nav-item w-full text-left">
              <ShoppingBag className="nav-icon" />
              <span class="sidebar-label flex-1">Pedidos</span>
              <ChevronRight className="h-3.5 w-3.5 submenu-arrow sidebar-label" />
              <span class="nav-tooltip">Pedidos</span>
            </button>
            <div class="sidebar-submenu pl-9 space-y-0.5" id="orders-submenu">
              <a href="/orders" class={`sidebar-nav-item text-[0.8125rem] ${currentPath === '/orders' || currentPath === '/orders/' ? 'active' : ''}`}>
                <ClipboardList className="nav-icon" />
                <span class="sidebar-label">Todos los Pedidos</span>
              </a>
              <a href="/orders/coupons" class={`sidebar-nav-item text-[0.8125rem] ${currentPath.startsWith('/orders/coupons') ? 'active' : ''}`}>
                <Tag className="nav-icon" />
                <span class="sidebar-label">Cupones</span>
              </a>
              <a href="/orders/shipping" class={`sidebar-nav-item text-[0.8125rem] ${currentPath.startsWith('/orders/shipping') ? 'active' : ''}`}>
                <Truck className="nav-icon" />
                <span class="sidebar-label">Envios</span>
              </a>
            </div>

            <a href="/users" class={`sidebar-nav-item ${currentPath.startsWith('/users') ? 'active' : ''}`}>
              <Users className="nav-icon" />
              <span class="sidebar-label">Usuarios</span>
              <span class="nav-tooltip">Usuarios</span>
            </a>

            <!-- Productos group -->
            <button onclick="toggleSubmenu('products')" class="sidebar-nav-item w-full text-left">
              <Package className="nav-icon" />
              <span class="sidebar-label flex-1">Productos</span>
              <ChevronRight className="h-3.5 w-3.5 submenu-arrow sidebar-label" />
              <span class="nav-tooltip">Productos</span>
            </button>
            <div class="sidebar-submenu pl-9 space-y-0.5" id="products-submenu">
              <a href="/products" class={`sidebar-nav-item text-[0.8125rem] ${currentPath === '/products' || currentPath === '/products/' ? 'active' : ''}`}>
                <Package className="nav-icon" />
                <span class="sidebar-label">Todos los Productos</span>
              </a>
              <a href="/products/categories" class={`sidebar-nav-item text-[0.8125rem] ${currentPath.startsWith('/products/categories') ? 'active' : ''}`}>
                <Grid3X3 className="nav-icon" />
                <span class="sidebar-label">Categorías</span>
              </a>
            </div>

            <div class="sidebar-section-label">Finanzas</div>

            <a href="/payments-table" class={`sidebar-nav-item ${currentPath.startsWith('/payments') ? 'active' : ''}`}>
              <CreditCard className="nav-icon" />
              <span class="sidebar-label">Pagos</span>
              <span class="nav-tooltip">Pagos</span>
            </a>

            <a href="/analytics" class={`sidebar-nav-item ${currentPath.startsWith('/analytics') ? 'active' : ''}`}>
              <BarChart3 className="nav-icon" />
              <span class="sidebar-label">Analytics</span>
              <span class="nav-tooltip">Analytics</span>
            </a>
          </nav>

          <!-- Logout + admin email -->
          <div class="px-3 py-3 border-t border-inherit">
            {adminSession && (
              <div class="sidebar-label mb-2 px-1">
                <p class="text-xs text-muted-foreground truncate" title={adminSession.admin.email}>
                  {adminSession.admin.email}
                </p>
              </div>
            )}
            <button onclick="handleLogout()" class="sidebar-logout">
              <LogOut className="nav-icon flex-shrink-0" />
              <span class="nav-tooltip">Cerrar Sesión</span>
            </button>
          </div>
        </div>
      </aside>
    )}

    <main id="main-content" class="flex-1 flex flex-col">
      <slot />
    </main>

    <footer id="footer" class="py-4 text-center">
      <div class="container mx-auto px-4">
        <p class="text-sm">
          Hecho con amor por su hermanito <a href="https://instagram.com/chocolohans" target="_blank" rel="noopener noreferrer" class="font-bold">Yey</a>
        </p>
      </div>
    </footer>

<script is:inline>
  (function() {
    var EXPANDED_W = '256px';
    var COLLAPSED_W = '64px';
    var STORAGE_KEY = 'sidebar-collapsed';

    function isCollapsed() {
      var sb = document.getElementById('sidebar');
      return sb && sb.classList.contains('sidebar-collapsed');
    }

    function applyState(collapsed, skipTransition) {
      var sb = document.getElementById('sidebar');
      if (!sb) return;

      if (skipTransition) {
        sb.style.transition = 'none';
        document.getElementById('main-content').style.transition = 'none';
        document.getElementById('footer').style.transition = 'none';
      }

      var w = collapsed ? COLLAPSED_W : EXPANDED_W;
      document.documentElement.style.setProperty('--sidebar-width', w);

      if (collapsed) {
        sb.classList.add('sidebar-collapsed');
      } else {
        sb.classList.remove('sidebar-collapsed');
      }

      // Toggle icons
      var ci = sb.querySelector('.toggle-collapse-icon');
      var ei = sb.querySelector('.toggle-expand-icon');
      if (ci) ci.classList.toggle('hidden', collapsed);
      if (ei) ei.classList.toggle('hidden', !collapsed);

      if (skipTransition) {
        // Force reflow then re-enable transitions
        sb.offsetHeight;
        sb.style.transition = '';
        document.getElementById('main-content').style.transition = '';
        document.getElementById('footer').style.transition = '';
      }

      // Close submenus when collapsing
      if (collapsed) {
        document.querySelectorAll('.sidebar-submenu.open').forEach(function(sm) {
          sm.classList.remove('open');
        });
        document.querySelectorAll('.submenu-arrow.rotated').forEach(function(a) {
          a.classList.remove('rotated');
        });
      }
    }

    // Expose globals
    window.toggleSidebar = function() {
      var next = !isCollapsed();
      applyState(next, false);
      try { localStorage.setItem(STORAGE_KEY, next ? '1' : '0'); } catch(e) {}
    };

    window.toggleSubmenu = function(id) {
      if (isCollapsed()) {
        // Expand sidebar first, then open submenu
        applyState(false, false);
        try { localStorage.setItem(STORAGE_KEY, '0'); } catch(e) {}
        setTimeout(function() {
          var sm = document.getElementById(id + '-submenu');
          var arrow = document.querySelector('button[onclick="toggleSubmenu(\'' + id + '\')"] .submenu-arrow');
          if (sm) sm.classList.add('open');
          if (arrow) arrow.classList.add('rotated');
        }, 100);
        return;
      }
      var sm = document.getElementById(id + '-submenu');
      var arrow = document.querySelector('button[onclick="toggleSubmenu(\'' + id + '\')"] .submenu-arrow');
      if (!sm) return;
      sm.classList.toggle('open');
      if (arrow) arrow.classList.toggle('rotated');
    };

    // Mobile
    window.openMobileSidebar = function() {
      var sb = document.getElementById('sidebar');
      var ov = document.getElementById('sidebar-overlay');
      if (sb) sb.classList.add('mobile-open');
      if (ov) ov.classList.add('visible');
      // Ensure expanded on mobile
      applyState(false, true);
    };

    window.closeMobileSidebar = function() {
      var sb = document.getElementById('sidebar');
      var ov = document.getElementById('sidebar-overlay');
      if (sb) sb.classList.remove('mobile-open');
      if (ov) ov.classList.remove('visible');
    };

    // Init
    document.addEventListener('DOMContentLoaded', function() {
      var sb = document.getElementById('sidebar');
      if (!sb) {
        document.documentElement.style.setProperty('--sidebar-width', '0px');
        return;
      }

      var isMobile = window.innerWidth < 768;

      if (isMobile) {
        // Mobile: hidden off-screen, always expanded when visible
        applyState(false, true);
        document.documentElement.style.setProperty('--sidebar-width', '0px');
      } else {
        // Desktop: restore state from localStorage
        var saved = '1'; // collapsed by default
        try { saved = localStorage.getItem(STORAGE_KEY) || '1'; } catch(e) {}
        applyState(saved === '1', true);
      }

      // Mobile hamburger
      var mobileBtn = document.getElementById('mobile-menu-btn');
      if (mobileBtn) mobileBtn.addEventListener('click', window.openMobileSidebar);

      // Overlay click closes mobile sidebar
      var ov = document.getElementById('sidebar-overlay');
      if (ov) ov.addEventListener('click', window.closeMobileSidebar);

      // Auto-open submenu for active page
      var path = sb.getAttribute('data-current-path') || '';
      if (path.startsWith('/orders')) {
        var osm = document.getElementById('orders-submenu');
        var oar = document.querySelector('button[onclick="toggleSubmenu(\'orders\')"] .submenu-arrow');
        if (osm && !isMobile) { osm.classList.add('open'); }
        if (oar && !isMobile) { oar.classList.add('rotated'); }
      }
      if (path.startsWith('/products')) {
        var psm = document.getElementById('products-submenu');
        var par = document.querySelector('button[onclick="toggleSubmenu(\'products\')"] .submenu-arrow');
        if (psm && !isMobile) { psm.classList.add('open'); }
        if (par && !isMobile) { par.classList.add('rotated'); }
      }

      // Logo theme
      updateLogoImages();
    });

    // Resize handler
    var resizeTimer;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function() {
        var isMobile = window.innerWidth < 768;
        if (isMobile) {
          document.documentElement.style.setProperty('--sidebar-width', '0px');
          window.closeMobileSidebar();
        } else {
          var saved = '1';
          try { saved = localStorage.getItem(STORAGE_KEY) || '1'; } catch(e) {}
          applyState(saved === '1', true);
        }
      }, 100);
    });

    // Logo images
    window.updateLogoImages = function() {
      var isDark = document.documentElement.classList.contains('dark');
      document.querySelectorAll('.logo-image').forEach(function(img) {
        var ds = img.getAttribute('data-dark-src');
        var ls = img.getAttribute('data-light-src');
        if (ds && ls) img.src = isDark ? ds : ls;
      });
    };

    // Logout con confirmación
    window.handleLogout = async function() {
      if (!confirm('¿Estás seguro de que deseas cerrar sesión?')) return;
      try {
        await fetch('/api/auth/logout', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
        window.location.href = '/';
      } catch(e) {
        console.error('[Auth] Error en logout:', e);
        window.location.href = '/';
      }
    };
  })();
</script>

<script>
  const getThemePreference = () => {
    if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
      return localStorage.getItem('theme');
    }
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  };
  const isDark = getThemePreference() === 'dark';
  document.documentElement.classList[isDark ? 'add' : 'remove']('dark');

  if (typeof localStorage !== 'undefined') {
    const observer = new MutationObserver(() => {
      const isDark = document.documentElement.classList.contains('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      if (typeof updateLogoImages === 'function') updateLogoImages();
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
  }

  document.addEventListener('DOMContentLoaded', function() {
    if (typeof updateLogoImages === 'function') updateLogoImages();
  });
</script>

  </body>
</html>
